# ── LLM Providers ──
use_ollama=True
ollama_base_url=http://localhost:11434
ollama_model_reasoning=qwen3:8b
ollama_model_fast=gemma3:latest
ollama_model_code=deepseek-coder:6.7b

use_groq=False
groq_api_key=
groq_model_reasoning=llama-3.3-70b-versatile
groq_model_fast=llama-3.1-8b-instant

# ── Web Search (Brave) ──
brave_api_key=

# ── App ──
auto_confirm=False
use_scoping_agent=True

# ── Credenciales legado (no necesarias con Ollama/Groq) ──
GEMINI_API_KEY=""
GOOGLE_API_KEY=""
CSE_API_KEY=""
CSE_CX=""
